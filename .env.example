# Polygon RPC endpoint (Alchemy, Infura, or other provider)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Rate limits for your RPC provider
POLYGON_RPC_MAX_GETLOGS_BLOCK_SPAN=10000
POLYGON_RPC_MAX_REQUESTS_PER_SECOND=10

# Other credentials
POLYNODE_API_KEY=your-private-key

# Path to SQLite database for scraped events (hot storage - active writes)
RPC_DB_PATH=./raw_data/hot/polygon_contract_events_v2.db

# Output directory for parquet exports (cold storage - archival)
POLYGON_CONTRACT_EVENTS_V2_DIR=./raw_data/cold/polygon_contract_events_v2

# Polygonscan API key (for downloading contract source code via Foundry cast)
ETHERSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
